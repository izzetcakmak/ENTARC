// Prisma Schema - Database models
// Defines User model for authentication

generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/arcent_mvp/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  emailVerified DateTime?
  image         String?
  walletAddress String?   // Arc Testnet wallet address
  role          UserRole  @default(INVESTOR)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  
  // Founder relations
  foundedProjects    Project[]           @relation("FounderProjects")
  
  // Investor relations
  sentProposals      InvestmentProposal[] @relation("InvestorProposals")
  receivedProposals  InvestmentProposal[] @relation("FounderReceivedProposals")
}

enum UserRole {
  INVESTOR
  FOUNDER
  BOTH
  ADMIN
}

// Project submitted by founders
model Project {
  id              String        @id @default(cuid())
  name            String
  tagline         String
  description     String        @db.Text
  category        ProjectCategory
  logoEmoji       String        @default("🚀")
  
  // Founder info
  founderId       String
  founder         User          @relation("FounderProjects", fields: [founderId], references: [id])
  founderEmail    String
  
  // GitHub info
  githubUrl       String?
  githubStars     Int           @default(0)
  githubForks     Int           @default(0)
  githubCommits   Int           @default(0)
  githubContributors Int        @default(0)
  
  // Social info
  twitterHandle   String?
  twitterFollowers Int          @default(0)
  discordUrl      String?
  websiteUrl      String?
  
  // Funding info
  fundingGoal     Float         @default(0)
  currentFunding  Float         @default(0)
  
  // AI Analysis
  aiTrustScore    Int?          // 0-100, calculated by AI
  aiAnalysis      Json?         // Full AI analysis JSON
  sentiment       Sentiment     @default(NEUTRAL)
  activityLevel   ActivityLevel @default(MODERATE)
  riskLevel       RiskLevel     @default(MEDIUM)
  
  // Status
  status          ProjectStatus @default(PENDING_REVIEW)
  isVerified      Boolean       @default(false)
  
  // Timestamps
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  reviewedAt      DateTime?
  
  // Relations
  milestones      Milestone[]
  proposals       InvestmentProposal[]
}

enum ProjectCategory {
  DEFI
  INFRASTRUCTURE
  GAMING
  NFT
  DAO
  SOCIAL
  AI
  OTHER
}

enum Sentiment {
  BULLISH
  NEUTRAL
  BEARISH
}

enum ActivityLevel {
  HIGH
  MODERATE
  LOW
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum ProjectStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  FUNDED
  COMPLETED
}

// Milestones for projects
model Milestone {
  id              String        @id @default(cuid())
  projectId       String
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  title           String
  description     String
  targetAmount    Float         // USDC amount for this milestone
  percentage      Float         // Percentage of total funding
  orderIndex      Int           // Order in milestone sequence
  
  status          MilestoneStatus @default(PENDING)
  completedAt     DateTime?
  releasedAt      DateTime?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  RELEASED
  DISPUTED
}

// Investment Proposals
model InvestmentProposal {
  id              String        @id @default(cuid())
  
  // Investor
  investorId      String
  investor        User          @relation("InvestorProposals", fields: [investorId], references: [id])
  investorWallet  String?
  
  // Project & Founder
  projectId       String
  project         Project       @relation(fields: [projectId], references: [id])
  founderId       String
  founder         User          @relation("FounderReceivedProposals", fields: [founderId], references: [id])
  
  // Proposal details
  proposedAmount  Float         // USDC amount
  proposedROI     Float?        // Expected ROI percentage
  message         String?       @db.Text
  milestones      Json?         // Proposed milestone structure
  terms           Json?         // Agreement terms
  
  // Status
  status          ProposalStatus @default(PENDING)
  
  // Negotiation
  counterAmount   Float?        // Founder's counter offer
  counterMessage  String?       @db.Text
  
  // Final agreement
  agreedAmount    Float?
  agreedAt        DateTime?
  
  // Timestamps
  expiresAt       DateTime
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // On-chain data (when escrow is created)
  escrowTxHash    String?
  escrowAddress   String?
}

enum ProposalStatus {
  PENDING
  COUNTERED
  ACCEPTED
  REJECTED
  EXPIRED
  FUNDED
  DISPUTED
  COMPLETED
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
