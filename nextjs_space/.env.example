# ENTARC environment variables — copy to .env and fill in your own values.
# Never commit .env to the repository.

# PostgreSQL connection string
DATABASE_URL='postgresql://USER:PASSWORD@HOST:5432/DATABASE'

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Google Analytics (optional)
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google SSO (Google Cloud Console → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Abacus AI platform
ABACUSAI_API_KEY=
WEB_APP_ID=
NOTIF_ID_NEW_INVESTMENT_PROPOSAL=
NOTIF_ID_PROPOSAL_STATUS_UPDATE=

# Market data providers
COINMARKETCAP_API_KEY=
DUNE_ANALYTICS_API_KEY=

# Circle Agent Stack (https://console.circle.com)
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
